                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Analitik"
                ],
                "summary": "IP Geçmiş Analitiği Sorgulama",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Sorgulanacak IP Adresi (Örn: 127.0.0.1)",

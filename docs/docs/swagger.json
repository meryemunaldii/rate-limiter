                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Başarılı Rapor Çıktısı",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "400": {
                        "description": "Eksik parametre hatası",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Veritabanı sorgu hatası",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    }
